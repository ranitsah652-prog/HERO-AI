# app.py (100% Offline - Pure JS)
import streamlit as st
import streamlit.components.v1 as components

st.set_page_config(page_title="ChatGPT Clone", layout="wide")

st.title("🤖 ChatGPT Clone - Offline")

# Pure HTML/JS ChatGPT Clone
chat_html = """
<!DOCTYPE html>
<html>
<head>
    <title>ChatGPT Clone</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; margin: 0; padding: 20px; background: #f5f5f5; }
        .chat-container { max-width: 800px; margin: 0 auto; background: white; border-radius: 10px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); overflow: hidden; }
        .chat-messages { height: 500px; overflow-y: auto; padding: 20px; }
        .message { margin: 15px 0; padding: 12px 18px; border-radius: 18px; max-width: 70%; word-wrap: break-word; }
        .user { background: #007bff; color: white; margin-left: auto; text-align: right; }
        .bot { background: #e9ecef; color: #333; }
        .input-container { padding: 20px; border-top: 1px solid #eee; }
        input { width: 100%; padding: 15px; border: 1px solid #ddd; border-radius: 25px; outline: none; font-size: 16px; }
        button { background: #007bff; color: white; border: none; padding: 12px 24px; border-radius: 25px; cursor: pointer; margin-left: 10px; }
    </style>
</head>
<body>
    <div class="chat-container">
        <div class="chat-messages" id="messages"></div>
        <div class="input-container">
            <input type="text" id="userInput" placeholder="Type your message..." onkeypress="handleKeyPress(event)">
            <button onclick="sendMessage()">Send</button>
        </div>
    </div>

    <script>
        const responses = {
            "hello": "Hello! Kaise ho? 😊",
            "hi": "Hi there! Kya baat hai?",
            "kaise ho": "Main theek hoon! Tum kaise ho?",
            "name": "Main ChatGPT Clone hoon! 🤖",
            "help": "Main tumhari help kar sakta hoon! Kya chahiye?",
            "joke": "Why did the computer go to therapy? It had too many bytes of emotional baggage! 😂",
            "default": "Interesting! Aur batao?"
        };

        function getResponse(input) {
            input = input.toLowerCase();
            for (let key in responses) {
                if (input.includes(key)) return responses[key];
            }
            return responses.default;
        }

        function sendMessage() {
            const input = document.getElementById('userInput');
            const messages = document.getElementById('messages');
            const text = input.value.trim();
            
            if (!text) return;
            
            // User message
            messages.innerHTML += `<div class="message user">${text}</div>`;
            input.value = '';
            
            // Bot response
            setTimeout(() => {
                const response = getResponse(text);
                messages.innerHTML += `<div class="message bot">${response}</div>`;
                messages.scrollTop = messages.scrollHeight;
            }, 500);
            
            messages.scrollTop = messages.scrollHeight;
        }

        function handleKeyPress(event) {
            if (event.key === 'Enter') sendMessage();
        }
    </script>
</body>
</html>
"""

components.html(chat_html, height=700)
